# Direct Groq (recommended for local dev and Cloudflare Workers)
GROQ_API_KEY=

# Or an AI gateway key (optional alternative to direct Groq)
# AI_GATEWAY_API_KEY=

# Optional model override (must be available on your Groq account)
# CORE_AI_MODEL=llama-3.3-70b-versatile
# Kimi models (e.g. moonshotai/kimi-k2-instruct-0905) require Groq paid tier.

# Cloudflare production: add GROQ_API_KEY in the dashboard under
# Workers & Pages → core-portfolio-app → Settings → Variables and Secrets.
# Or: wrangler secret put GROQ_API_KEY
# Use `pnpm run deploy -- --keep-vars` so deploys do not wipe dashboard secrets.

# Contact form (Resend) — https://resend.com/domains
RESEND_API_KEY=
CONTACT_TO_EMAIL=matinkaviiani@gmail.com
# Use a verified domain in Resend (required for production delivery):
RESEND_FROM=Portfolio Contact <contact@matinkaviani.net>
# Until matinkaviani.net is verified, Resend only delivers to the account owner email
# (onboarding@resend.dev + CONTACT_TO_EMAIL=your-resend-account@gmail.com).

# Bot protection (Cloudflare Turnstile) — add matinkaviani.net, www.matinkaviani.net, localhost
TURNSTILE_SECRET_KEY=
# Local dev can use NEXT_PUBLIC_*; production Cloudflare needs TURNSTILE_SITE_KEY as a Worker var:
TURNSTILE_SITE_KEY=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
